{
    "appName": "djong-reader-engine",
    "sonarExcludePath": "ns-cicd/*",
    "is_unit_test": "yes",
    "language": "go",
    "testPackages": "./graphqlutils/... ./graph/model/...",
    "sonarCoverageInclusions": "graphqlutils/**/*.go,graph/model/**/*.go",
    "sonarTestInclusions": "graphqlutils/**/*_test.go,graph/model/**/*_test.go",
    "enableSCA": "true",
    "enableSCAHardGate": "false",
    "needEnvfile": "yes",
    "envKey": ["APP_PORT","DATABASE_URL","DB_HOST","DB_USER","DB_PASSWORD","DB_NAME","DB_PORT"]
}